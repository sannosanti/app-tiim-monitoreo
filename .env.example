# Copia este archivo como .env y completa los valores
# En Railway configura estas mismas variables en el panel

# Email destino del reporte diario
EMAIL_TO=tu@email.com

# Email remitente (debe estar verificado en Resend)
EMAIL_FROM=monitor@tudominio.com

# API Key de Resend (https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Horario del reporte (cron, hora Colombia)
# "0 8 * * *"  = todos los días a las 8am
# "0 8,20 * * *" = 8am y 8pm
CHECK_CRON=0 8 * * *
