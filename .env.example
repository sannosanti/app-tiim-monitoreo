# Copia este archivo como .env y completa los valores
# En Railway configura estas mismas variables en el panel

# Email destino del reporte diario
EMAIL_TO=tu@email.com

# Email remitente (debe coincidir con tu cuenta SMTP)
EMAIL_FROM=monitor@tudominio.com

# SMTP — opciones recomendadas:
# Gmail:      smtp.gmail.com  puerto 587
# Outlook:    smtp.office365.com  puerto 587
# Resend:     smtp.resend.com  puerto 587  (recomendado, gratis)
# Brevo:      smtp-relay.brevo.com  puerto 587  (gratis)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu@gmail.com
SMTP_PASS=tu_app_password

# Horario del reporte (cron, hora Colombia)
# "0 8 * * *"  = todos los días a las 8am
# "0 8,20 * * *" = 8am y 8pm
CHECK_CRON=0 8 * * *
